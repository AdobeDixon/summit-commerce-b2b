{
  "name": "@adobe/aem-boilerplate-commerce",
  "private": true,
  "version": "2.0.0",
  "description": "Starter project for Adobe Commerce on Edge Delivery Services",
  "scripts": {
    "lint:js": "eslint .",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "start": "bash scripts/start.sh",
    "install:dropins": "node build.mjs && node postinstall.js",
    "postinstall": "npm run install:dropins",
    "postupdate": "npm run install:dropins",
    "build:json": "npm-run-all -p build:json:models build:json:definitions build:json:filters",
    "build:json:models": "merge-json-cli -i \"models/_component-models.json\" -o \"component-models.json\"",
    "build:json:definitions": "merge-json-cli -i \"models/_component-definition.json\" -o \"component-definition.json\"",
    "build:json:filters": "merge-json-cli -i \"models/_component-filters.json\" -o \"component-filters.json\"",
    "prepare": "husky",
    "create-user": "node scripts/create-commerce-user.mjs",
    "update-product-names": "node scripts/update-commerce-product-names.mjs",
    "migrate-masonry-skus": "node scripts/migrate-legacy-skus-to-masonry.mjs",
    "create-masonry-products": "node scripts/create-masonry-products.mjs",
    "set-masonry-stock": "node scripts/set-masonry-stock.mjs",
    "assign-masonry-shared-catalog": "node scripts/assign-masonry-shared-catalog.mjs",
    "assign-masonry-brick-category": "node scripts/assign-masonry-brick-category.mjs",
    "list-shared-catalogs": "node scripts/list-shared-catalogs.mjs",
    "inspect-masonry-skus": "node scripts/inspect-masonry-skus.mjs",
    "assign-masonry-product-websites": "node scripts/assign-masonry-product-websites.mjs",
    "align-masonry-with-pallets": "node scripts/align-masonry-with-pallets.mjs",
    "link-masonry-pallet-category": "node scripts/link-masonry-pallet-equipment-category.mjs",
    "playwright-mcp": "playwright-mcp",
    "playwright-mcp:bridge": "playwright-mcp --extension"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hlxsites/aem-boilerplate-commerce.git"
  },
  "author": "Adobe",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/hlxsites/aem-boilerplate-commerce/issues"
  },
  "homepage": "https://github.com/hlxsites/aem-boilerplate-commerce#readme",
  "devDependencies": {
    "@adobe/aem-cli": "^16.5.8",
    "@babel/eslint-parser": "7.28.6",
    "@dropins/build-tools": "1.0.1",
    "@playwright/mcp": "^0.0.70",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "husky": "^9.1.7",
    "merge-json-cli": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.5",
    "stylelint": "17.1.1",
    "stylelint-config-standard": "40.0.0"
  },
  "dependencies": {
    "@adobe/adobe-client-data-layer": "^3.0.1",
    "@adobe/magento-storefront-event-collector": "^1.15.0",
    "@adobe/magento-storefront-events-sdk": "^1.15.0",
    "@dropins/storefront-account": "~3.1.0",
    "@dropins/storefront-auth": "~3.1.0",
    "@dropins/storefront-cart": "~3.1.0",
    "@dropins/storefront-checkout": "~3.1.0",
    "@dropins/storefront-company-management": "~1.1.0",
    "@dropins/storefront-company-switcher": "~1.1.0",
    "@dropins/storefront-order": "~3.1.0",
    "@dropins/storefront-payment-services": "~3.0.0",
    "@dropins/storefront-pdp": "~3.0.1",
    "@dropins/storefront-personalization": "~3.1.0",
    "@dropins/storefront-product-discovery": "~3.0.0",
    "@dropins/storefront-purchase-order": "~1.1.0",
    "@dropins/storefront-quote-management": "~1.1.0",
    "@dropins/storefront-recommendations": "~3.0.0",
    "@dropins/storefront-requisition-list": "1.1.0",
    "@dropins/storefront-wishlist": "~3.1.0",
    "@dropins/tools": "~1.7.0"
  }
}
