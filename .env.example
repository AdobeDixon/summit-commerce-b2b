# Copy to .env and set values. .env is gitignored — do not commit real secrets.
# Used by: npm run create-user, npm run update-product-names

IMS_CLIENT_ID=
IMS_CLIENT_SECRET=
IMS_ORG_ID=

# Optional: override REST base if different from config.json commerce-endpoint (without /graphql)
# API_ENDPOINT=

# scripts/seed-terrablock-company-credit.mjs — optional overrides
# TERRABLOCK_COMPANY_NAME=Terrablock
# TERRABLOCK_CREDIT_LIMIT=750000
# TERRABLOCK_CREDIT_CURRENCY=USD
